<th align="center">-&gt;</th>
<th align="center">-&gt;</th>
</tr>
</thead>
<tbody><tr>
<td align="center">1:A-&gt;B</td>
<td align="center">2:A-&gt;C</td>
<td align="center">1:B-&gt;C</td>
<td align="center">3:A-&gt;B</td>
<td align="center">1:C-&gt;A</td>
<td align="center">2:C-&gt;B</td>
<td align="center">1:A-&gt;B</td>
</tr>
<tr>
